# SQLite (relative to project root)
DATABASE_URL=sqlite:///./data/ideavault.db

# Telegram (python-telegram-bot)
TELEGRAM_BOT_TOKEN=

# Logging
LOG_LEVEL=INFO

# FastAPI / uvicorn
API_HOST=0.0.0.0
API_PORT=8000
# If set, mutating POST endpoints require header X-API-Key (same value). Leave empty for open local API.
API_KEY=your-secret-key
# user_id для строки sessions при работе с /ui/*
WEB_UI_USER_ID=web-ui

# Optional: OpenAI answer layer (retrieval always runs first; LLM only rephrases grounded notes)
LLM_ENABLED=false
OPENAI_API_KEY=
# Used for chat LLM and Telegram voice → text (Whisper-class API)
OPENAI_MODEL=gpt-4o-mini
# STT model for voice messages (default whisper-1)
OPENAI_STT_MODEL=whisper-1
STT_TIMEOUT_SECONDS=60
LLM_TIMEOUT_SECONDS=25
# Sampling temperature for Chat Completions (default 0.2 if omitted)
LLM_TEMPERATURE=0.2
# Upper bound on completion length (tokens); default 200 if omitted — keeps replies Telegram-friendly
LLM_MAX_TOKENS=200
# Verbose safe LLM logs (query preview, note ids, prompt length); never logs API key or full bodies
LLM_DEBUG_LOGGING=false
